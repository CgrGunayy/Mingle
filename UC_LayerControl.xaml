<UserControl x:Class="MingleWPF.UC_LayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:MingleWPF"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="200">

    <StackPanel>
        <StackPanel Height="50" Background="#1C1B1B" Orientation="Horizontal">
            <iconPacks:PackIconBootstrapIcons x:Name="layerIcon" Margin="15, 0, 0, 0" Width="18" Height="18" Kind="CameraVideo" Foreground="#E0BEC1"  VerticalAlignment="Center"/>
            <StackPanel Orientation="Vertical">
                <Label x:Name="layerTitle" Content="Video Layer" Margin="5, 2, 10, 0" Foreground="#E0BEC1" FontSize="14" FontWeight="Medium"  VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconBootstrapIcons x:Name="layerButton01" Margin="15, 0, 0, 0" Width="14" Height="14" Kind="Eye" Foreground="#E5E2E1"  VerticalAlignment="Center"/>
                    <iconPacks:PackIconBootstrapIcons x:Name="layerButton02" Margin="10, 0, 0, 0" Width="14" Height="14" Kind="UnlockFill" Foreground="#E5E2E1"  VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </StackPanel>
   
</UserControl>
