## Visual Studio ve WPF için standart .gitignore

# Kullanıcıya özel dosyalar (User-specific files)
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio 2015/2017/2019/2022 önbellek ve ayar dizini
.vs/

# Derleme sonuçları (Build results) - EN ÖNEMLİ KISIM
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# WPF Tasarımcı (UIDesigner) yapılandırmaları
*.xaml.ui.txt

# NuGet Paketleri
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# MSTest ve NUnit Test Sonuçları
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.err
nunit-*.out

# Visual Studio önbellek (cache) dosyaları
*.[Cc]ache
!?*.[Cc]ache/

# Çeşitli yedekleme ve geçici dosyalar
~$*
*~
*.dbmdl
*.pfx
*.publishsettings

# Eski projeleri yükseltirken oluşan yedekler (Zaten Git kullanıyoruz, bunlara gerek yok)
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server veritabanı dosyaları (Eğer projenizde yerel DB kullanıyorsanız)
*.mdf
*.ldf
*.ndf